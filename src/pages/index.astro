---
import Header from "../components/Header.astro";
import background from "../assets/valdivia.jpg";
import Base from "../layouts/Base.astro";
import { Link } from "@/components/ui/link";
import { Info, Bell, Terminal } from "lucide-react";
import { Image } from "astro:assets";
import logoHero from "../assets/logo-hero.svg";
---

<Base title="Inicio" bodyClasses={["dark"]}>
  <Header variant="home" />
  <main class="flex flex-col h-[100dvh] justify-center items-center">
    <Image
      class="absolute top-0 left-0 h-[100dvh] w-full -z-10 filter brightness-[0.5] object-cover object-[90%]"
      src={background}
      alt="Valdivia y su río"
      width={1920}
      quality={75}
    />
    <div id="hero" class="flex flex-col items-center">
      <div id="hero-text" class="flex flex-col items-center">
        <Image
          src={logoHero}
          alt="CIPC"
          class="w-[clamp(18rem,30vw,40rem)]"
        />
        <h2
          class="mt-4 text-center font-title text-[clamp(1rem,2.5vw,1.75rem)] font-extrabold text-white [text-shadow:0_2px_25px_rgba(0,0,0,1),0_0_12px_rgba(0,0,0,1)]"
        >
          Campamento Invernal de <span class="text-logo-orange">Programación Competitiva</span>
        </h2>
        <h3
          id="hero-subtitle"
          class="mt-4 text-md lg:text-lg text-center text-white text-shadow-black text-shadow-lg"
        >
          20 al 31 de julio, 2026 <br /> Valdivia  <br /> Universidad San Sebastián y Universidad Austral de Chile
        </h3>
        <h2
          class="mt-4 text-lg lg:text-lg text-center text-white text-shadow-black text-shadow-lg"
        >
          Primer llamado de inscripciones abierto hasta el 14 de Junio
        </h2>
      </div>
      <div class="flex flex-col items-center">
        <Link
          variant="default"
          size="lg"
          className="m-2 bg-logo-orange text-white hover:bg-logo-orange/90"
          href="https://forms.gle/8XKYezsWZ7rLYSeJ6"
          target="_blank"
          rel="noopener noreferrer"
        >
          <Terminal className="mr-2" /> Inscríbete aquí
        </Link>
        <Link variant="secondary" size="lg" className="m-2" href="/acerca/"
          ><Info /> Más información</Link
        >
      </div>
    </div>
  </main>
</Base>
